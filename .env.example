# === NextAuth ===
# Secret utilise pour signer les JWT de session. Obligatoire en production.
# Generer une valeur aleatoire : `openssl rand -base64 32`
AUTH_SECRET=

# === Base de donnees (Neon / Postgres) ===
# Fourni par Vercel Storage > Neon. Ne jamais committer.
DATABASE_URL=

# === Vercel Blob (stockage PDF) ===
# Fourni par Vercel Storage > Blob.
BLOB_READ_WRITE_TOKEN=

# === Stripe ===
# Clef secrete cote serveur (optionnelle en mode demo, requise pour les paiements).
STRIPE_SECRET_KEY=sk_test_...
# Clef publique cote client.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret de verification du webhook Stripe (Dashboard > Developers > Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_...

# === URL publique de l'application ===
# Utilise pour construire les success_url / cancel_url Stripe de maniere fiable.
# En prod Vercel, laisser vide : request.nextUrl.origin sera utilise.
NEXT_PUBLIC_APP_URL=
